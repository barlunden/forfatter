---
import { Image } from "astro:assets";
import type { ImageMetadata } from 'astro';

interface Props {
  image?: ImageMetadata;
  imageSrc?: string;
  imageAlt: string;
}

const { image, imageSrc, imageAlt } = Astro.props;
---
<section class="image-block">
    <div class="p-image">
        {image && <Image src={image} alt={imageAlt} class="rounded-4xl grayscale" />}
        {imageSrc && <img src={imageSrc} alt={imageAlt} class="rounded-4xl" />}
    </div>
</section>
